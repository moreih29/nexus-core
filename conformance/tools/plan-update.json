              "status": "pending"
            }
          ],
          "research_summary": "Reviewed codebase for state dependencies.",
          "created_at": "2026-04-13T00:00:00.000Z"
        }
      }
    },
    "action": {
      "tool": "plan_update",
      "params": {
        "action": "remove"
      }
