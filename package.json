{
  "name": "@moreih29/nexus-core",
  "version": "0.13.0",
  "description": "Nexus ecosystem authoring layer — canonical agents/skills/hooks and 3-harness build pipeline (Claude Code, OpenCode, Codex)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moreih29/nexus-core.git"
  },
  "homepage": "https://github.com/moreih29/nexus-core#readme",
  "bugs": {
    "url": "https://github.com/moreih29/nexus-core/issues"
  },
  "exports": {
    ".": null,
    "./agents/*": "./assets/agents/*",
    "./skills/*": "./assets/skills/*",
    "./docs/*": "./docs/*",
    "./mcp": "./dist/mcp/server.js",
    "./assets/lsp-servers.json": "./assets/lsp-servers.json",
    "./assets/schema/lsp-servers.schema.json": "./assets/schema/lsp-servers.schema.json"
  },
  "files": [
    "assets",
    "docs",
    "scripts",
    "dist"
  ],
  "bin": {
    "nexus-mcp": "./dist/mcp/server.js",
    "nexus-core": "./scripts/cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "build": "bun run clean && bun run build:runtime && bun run build:assets",
    "build:runtime": "tsc -p tsconfig.build.json",
    "build:assets": "bun run scripts/build-agents.ts && bun run scripts/build-hooks.ts",
    "clean": "rm -rf dist",
    "test": "bun run build:runtime && bun test --max-concurrency=1 src/ scripts/",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build",
    "prepublishOnly": "bun run test"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/bun": "latest",
    "ajv": "^8",
    "ajv-errors": "^3",
    "ajv-formats": "^3",
    "tinyglobby": "^0.2",
    "typescript": "^5",
    "yaml": "^2",
    "zod": "^3.23.0"
  }
}
