{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "assets/hooks/**/handler.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
