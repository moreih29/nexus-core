{
  "$schema": "./schema/lsp-servers.schema.json",
  "languages": {
    "typescript": {
      "extensions": {
        "ts": "typescript",
        "tsx": "typescriptreact",
        "js": "javascript",
        "jsx": "javascriptreact",
        "mjs": "javascript",
        "cjs": "javascript",
        "mts": "typescript",
        "cts": "typescript"
      },
      "server": {
        "command_chain": ["bunx", "npx"],
        "args": ["typescript-language-server", "--stdio"]
      },
      "install_hint": "npm i -g typescript-language-server"
    },
    "python": {
      "extensions": {
        "py": "python",
        "pyi": "python"
      },
      "server": {
        "command_chain": ["bunx", "npx"],
        "args": ["pyright-langserver", "--stdio"]
      },
      "install_hint": "npm i -g pyright"
    },
    "rust": {
      "extensions": {
        "rs": "rust"
      },
      "server": {
        "command_chain": ["rust-analyzer"],
        "search_paths": ["~/.cargo/bin/rust-analyzer"],
        "args": []
      },
      "install_hint": "rustup component add rust-analyzer"
    },
    "go": {
      "extensions": {
        "go": "go"
      },
      "server": {
        "command_chain": ["gopls"],
        "search_paths": ["~/go/bin/gopls", "/usr/local/go/bin/gopls"],
        "args": ["serve"]
      },
      "install_hint": "go install golang.org/x/tools/gopls@latest"
    }
  }
}
